<style>
  .btn-search {
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }

  .btn-search:hover {
    background-color: #fe424d;
    color: white;
  }

  .btn-search i {
    display: inline;
    margin-right: 6px;
  }

  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 3rem 0.5rem 3rem;
    font-size: 1rem;
  }

  @media (max-width: 767px) {

    .navbar-collapse {
      background-color: rgba(255, 157, 157, 0.8);
      z-index: 1;
      padding: 1rem;
      border-radius: 10px;
    }

  }

  .search-main {
    box-shadow: 0.5px 1px 0.5px rgb(180, 179, 179);
  }

  .btn-main {
    box-shadow: 1px 1.5px 1px rgba(255, 157, 157, 0.8);
  }
</style>
<nav class="navbar navbar-expand-md bg-body-tertiary border-bottom sticky-top">

  <div class="container-fluid">

    <a class="navbar-brand fa-compass" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler " id="nav_collapse_btn" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>



    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">


      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>



      <div class="navbar-nav ms-auto ">
        <form action="/listings/search" method="POST" class="d-flex" role="search">
          <input class="form-control me-2 search-inp search-main" type="search" placeholder="Search destination"
            aria-label="Search" name="category" />
          <button class="btn btn-search btn-main" type="submit"><i
              class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>




      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Become a host</a>
        <%if(!currUser){ %>
          <a class="nav-link" href="/signup"><b>SignUp</b></a>
          <a class="nav-link" href="/login"><b>Login</b></a>
          <% } %>
            <% if(currUser){ %>
              <a class="nav-link" href="/logout">LogOut</a>
              <% } %>
      </div>





    </div>

  </div>

</nav>